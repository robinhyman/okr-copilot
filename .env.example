# OKR Co-Pilot local development defaults
# Copy to .env and adjust if needed.

NODE_ENV=development

# API + web
API_PORT=4000
CORS_ORIGIN=http://localhost:5173
VITE_API_BASE_URL=
VITE_AUTH_STUB_TOKEN=dev-stub-token

# Local data stores
DATABASE_URL=postgresql://okr:okr@localhost:5432/okr_copilot?schema=public
REDIS_URL=redis://localhost:6379

# Product defaults
APP_REGION=UK/EU
DATA_RESIDENCY=uk-eu
DEFAULT_TIMEZONE=Europe/London

# Auth stub (MVP)
AUTH_STUB_ENABLED=true
AUTH_STUB_EMAIL=robin@localhost
AUTH_STUB_DISPLAY_NAME=Robin
AUTH_STUB_TOKEN=dev-stub-token
AUTH_GUARD_TOKEN=

# Twilio / reminders (disabled verification for local demo)
WHATSAPP_PROVIDER=twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
TWILIO_WHATSAPP_SANDBOX=true
TWILIO_STATUS_CALLBACK_URL=
TWILIO_INBOUND_WEBHOOK_PATH=/api/reminders/whatsapp/inbound
TWILIO_VERIFY_SIGNATURE=false
TWILIO_PUBLIC_BASE_URL=
REMINDER_WORKER_ENABLED=false
REMINDER_TICK_SECONDS=30

# AI draft provider
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com/v1
OKR_DRAFT_LLM_TIMEOUT_MS=15000
OKR_DRAFT_INPUT_MAX_CHARS=240
