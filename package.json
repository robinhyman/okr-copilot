{
  "name": "okr-copilot",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev -w @okr-copilot/api\" \"npm run dev -w @okr-copilot/web\"",
    "build": "npm run build -ws",
    "typecheck": "npm run typecheck -ws",
    "test": "npm run test -ws",
    "test:api": "npm run test -w @okr-copilot/api",
    "test:api:integration": "npm run test:integration -w @okr-copilot/api",
    "migrate": "npm run migrate -w @okr-copilot/api"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
