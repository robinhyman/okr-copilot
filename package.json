{
  "name": "okr-copilot",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev -w @okr-copilot/api\" \"npm run dev -w @okr-copilot/web\"",
    "build": "npm run build -ws",
    "typecheck": "npm run typecheck -ws",
    "test": "npm run test -ws",
    "verify": "./scripts/verify-workflow.sh",
    "test:api": "npm run test -w @okr-copilot/api",
    "test:api:integration": "cross-env TWILIO_VERIFY_SIGNATURE=false REMINDER_WORKER_ENABLED=false npm run test:integration -w @okr-copilot/api",
    "migrate": "cross-env NODE_ENV=development npm run migrate -w @okr-copilot/api",
    "setup:local": "node scripts/setup-local.mjs",
    "deploy:local": "./scripts/deploy-local.sh",
    "smoke:local": "./scripts/smoke-local.sh",
    "validate:linux-target": "./scripts/validate-linux-target.sh",
    "test:e2e:checkins": "playwright test -c e2e/playwright.checkins.config.ts",
    "e2e:checkins:local": "./scripts/run-e2e-checkins-local.sh",
    "e2e:checkins:linux": "./scripts/run-e2e-checkins-linux-container.sh",
    "release:checklist": "bash scripts/verify-pr-evidence.sh",
    "seed:demo": "./scripts/seed-demo.sh",
    "demo:prepare": "node scripts/demo-prepare.mjs",
    "release:gate": "node scripts/release-gate.mjs"
  },
  "devDependencies": {
    "@playwright/test": "^1.52.0",
    "concurrently": "^9.2.1",
    "cross-env": "^7.0.3"
  }
}
